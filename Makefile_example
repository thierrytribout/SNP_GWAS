# Makefile example to compile SNP_GWAS.f90 or Cumul_Res_SG.f90 code
# uncomment below at #PROG the program you want to compile
# comment below at PROG the other program not to be compiled

FC = ifort

VERSION ?= release

FFLAGS_release = -O3 -mcmodel=large -zero -nbs -implicitnone -save -list

FFLAGS_debug   = -mcmodel=large -zero -nbs -implicitnone -save -list -CB -g -check all -traceback -warn -fpe0 -ftrapuv

FFLAGS = $(FFLAGS_$(VERSION)) -mkl

PROG = SNP_GWAS
#PROG = Cumul_Res_SG

$(PROG): $(PROG).f90
	$(FC) $(FFLAGS) $< -o $@

clean:
	rm -f $(PROG) *.o *.mod
